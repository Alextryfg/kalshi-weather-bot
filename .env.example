# =================================================================
# Kalshi Weather Bot — Environment Configuration
# =================================================================
# Copy this file to `.env` and fill in your values.
# NEVER commit your real .env file. Use GitHub Actions Secrets for CI.

# ---------- Execution Mode ----------
# `simulation` (default) — no real orders sent, paper-trading only
# `live`                  — sends real orders to Kalshi. REQUIRES the
#                           CLI flag `--live` as well (defense in depth).
EXECUTION_MODE=simulation

# Simulation starting capital (USD)
SIM_INITIAL_CAPITAL=1000

# ---------- Kalshi API ----------
# Use the demo environment first! Only switch to prod when fully tested.
# Demo:  https://demo-api.kalshi.co/trade-api/v2
# Prod:  https://api.elections.kalshi.com/trade-api/v2
KALSHI_API_BASE=https://demo-api.kalshi.co/trade-api/v2

# Your Kalshi API Key ID (UUID). Get one in the Kalshi web UI under
# Account → API Keys. The corresponding private key is below.
KALSHI_API_KEY_ID=

# Your RSA private key in PEM format. Either inline it (with literal \n
# for newlines) OR set KALSHI_PRIVATE_KEY_PATH to a file path on disk.
KALSHI_PRIVATE_KEY=
KALSHI_PRIVATE_KEY_PATH=

# ---------- Strategy Parameters ----------
# Cities to forecast (comma-separated). Start small; expand later.
WEATHER_CITIES=New York,Chicago

# Minimum edge (in percentage points) required to take a trade. 0.5 = 0.5pp.
MIN_EDGE_PP=0.5

# Half-Kelly multiplier. 0.5 = half-Kelly. Lower = more conservative.
KELLY_FRACTION=0.5

# Max fraction of capital risked per trade (hard cap, after Kelly).
MAX_TRADE_FRACTION=0.05

# Stop-loss threshold (percentage points adverse move).
STOP_LOSS_PP=2.0

# ---------- Risk Gates ----------
MIN_ORDERBOOK_DEPTH=50
MAX_VOLATILITY_PP_1H=20
MAX_POSITION_FRACTION=0.10
DAILY_LOSS_CAP_FRACTION=0.10
MIN_HOURS_TO_SETTLEMENT=6
MIN_PRICE_CENTS=10
MAX_PRICE_CENTS=90
ENABLE_ENSEMBLE=true
ENABLE_BIAS_CORRECTION=true
ENABLE_METAR=true

# ---------- Database ----------
# Path to SQLite database file. Will be created on first run.
DB_PATH=./data/bot.db

# ---------- Logging ----------
LOG_LEVEL=info
